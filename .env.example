# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Ads OAuth
GOOGLE_ADS_CLIENT_ID=your-google-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# Meta Ads OAuth
META_ADS_APP_ID=your-meta-app-id
META_ADS_APP_SECRET=your-meta-app-secret

# OAuth Redirect Base URL (e.g., https://your-site.netlify.app)
OAUTH_REDIRECT_BASE_URL=http://localhost:8888
