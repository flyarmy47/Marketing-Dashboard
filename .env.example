# Database (Railway Postgres)
DATABASE_URL=postgresql://user:password@host:port/dbname

# JWT Secret (generate a random 64-char string)
JWT_SECRET=your-jwt-secret-here

# Google Ads OAuth
GOOGLE_ADS_CLIENT_ID=your-google-client-id
GOOGLE_ADS_CLIENT_SECRET=your-google-client-secret
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token

# Meta Ads OAuth
META_ADS_APP_ID=your-meta-app-id
META_ADS_APP_SECRET=your-meta-app-secret

# App URL (for OAuth redirects)
APP_URL=http://localhost:5173

# Port (Railway sets this automatically)
PORT=3000
