generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now()) @map("created_at")

  tenantUsers TenantUser[]

  @@map("users")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")

  tenantUsers      TenantUser[]
  connections      Connection[]
  metrics          Metric[]
  dashboardConfigs DashboardConfig[]

  @@map("tenants")
}

model TenantUser {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  role      String   @default("owner")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("tenant_users")
}

model Connection {
  id             String    @id @default(uuid())
  tenantId       String    @map("tenant_id")
  platform       String
  accessToken    String    @map("access_token")
  refreshToken   String?   @map("refresh_token")
  tokenExpiresAt DateTime? @map("token_expires_at")
  accountId      String?   @map("account_id")
  accountName    String?   @map("account_name")
  lastSyncedAt   DateTime? @map("last_synced_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  metrics Metric[]

  @@unique([tenantId, platform])
  @@index([tenantId])
  @@map("connections")
}

model Metric {
  id           String   @id @default(uuid())
  tenantId     String   @map("tenant_id")
  connectionId String   @map("connection_id")
  platform     String
  date         DateTime @db.Date
  impressions  BigInt   @default(0)
  clicks       BigInt   @default(0)
  spend        Decimal  @default(0) @db.Decimal(12, 2)
  conversions  BigInt   @default(0)
  reach        BigInt   @default(0)
  videoViews   BigInt   @default(0) @map("video_views")
  budget       Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at")

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  connection Connection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, date])
  @@index([tenantId, date])
  @@map("metrics")
}

model DashboardConfig {
  id         String   @id @default(uuid())
  tenantId   String   @unique @map("tenant_id")
  tileConfig Json     @default("[\"impressions\",\"clicks\",\"spend\",\"conversions\",\"ctr\",\"cpa\",\"roi\"]") @map("tile_config")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("dashboard_configs")
}
